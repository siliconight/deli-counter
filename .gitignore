# Build outputs — regenerable from specs, kept out of source control.
# (If you decide to commit release models, whitelist them explicitly below.)
build/*.glb
build/*.gltf
build/*.bin
build/*.obj
build/*.mtl
build/textures/
build/floorplans/

# Keep manifests tracked: they are the traceability record (text, tiny).
!build/*.manifest.json

__pycache__/
*.pyc
*.blend1

# Versioned release zips — build artifacts, attach to GitHub Releases instead.
dist/

# Local validation scratch (one-off walk drivers — not part of the tool).
# Root-anchored so the tracked recipe at docs/themes/gasstation/ is unaffected.
/phase4_walk.*
/resolver_check.py
/make_wall_module.py
/walk_test.gd
# Test module library the resolver walk writes into.
/dc-modules/

# Phase 0 evidence reports — regenerated by evidence.py / roundtrip.py /
# review_render.py on every build; the registry references them by path,
# CI/releases retain them. Manifests above stay tracked as before.
build/*.validation.json
build/*.combat_audit.json
build/*.navigation.json
build/*.roundtrip.json
build/review/
