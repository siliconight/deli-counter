{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://delicounter/level.schema.json",
  "title": "Deli Counter level spec",
  "type": "object",
  "required": [
    "name"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "assault",
        "heist",
        "survival"
      ]
    },
    "seed": {
      "type": "integer",
      "default": 1999
    },
    "grid": {
      "type": "number",
      "default": 0.5,
      "exclusiveMinimum": 0
    },
    "footprint_x": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "footprint_y": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "story_height": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "n_stories": {
      "type": "integer",
      "minimum": 1
    },
    "has_basement": {
      "type": "boolean"
    },
    "roof": {
      "type": "string",
      "enum": [
        "solid",
        "open",
        "none"
      ]
    },
    "roof_mode": {
      "type": "string",
      "enum": [
        "footprint",
        "per_room"
      ]
    },
    "roof_thick": {
      "type": [
        "number",
        "null"
      ],
      "exclusiveMinimum": 0
    },
    "wall_thick": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "floor_thick": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "collision": {
      "enum": [
        "convex",
        "trimesh",
        "none"
      ]
    },
    "auto_exterior": {
      "type": "boolean"
    },
    "scale_ref": {
      "type": "boolean"
    },
    "vertex_nuance": {
      "type": "boolean"
    },
    "modular": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Decompose walls into named swap-slots (modular art-pass) instead of one solid box per run. Omitted/null -> DC_MODULAR env -> off. new_level.py defaults new specs to true."
    },
    "module": {
      "type": [
        "number",
        "null"
      ],
      "description": "Module tile width (m) for tiling solid spans when modular. Omitted/null -> DC_MODULE env -> 2.0. <= 0 disables tiling (opening-decomposition only)."
    },
    "theme": {
      "type": [
        "string",
        "null"
      ],
      "description": "Resolver theme/kit: slots resolve to <type>_<theme>_<style>[_w<cm>][_<state>].glb. Omitted/null -> DC_THEME env -> greybox."
    },
    "state": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional model state (e.g. damaged, weathered); prefers a _<state> module variant. Omitted/null -> DC_STATE env -> none."
    },
    "module_library": {
      "type": [
        "string",
        "null"
      ],
      "description": "Path to the module library (zoo of swap modules), relative to the spec. Omitted/null -> DC_MODULE_LIB env -> resolver off."
    },
    "rarity": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "common",
        "uncommon",
        "rare",
        "very_rare",
        "legendary",
        null
      ],
      "description": "Optional building rarity tier. When set, the build stamps the tier + its canonical colour onto gameplay.json and every breachable door/breach anchor for the networked-door reveal. null/omitted = no rarity."
    },
    "building_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Stable id for the building. For a single DC build = the level name; the server keys is_revealed and the rarity roll on this. Emitted automatically; rarely hand-authored."
    },
    "assets_dir": {
      "type": "string"
    },
    "default_material": {
      "type": [
        "string",
        "null"
      ]
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "acoustic": {
            "enum": [
              "Default",
              "Air",
              "Glass",
              "Wood",
              "Drywall",
              "Concrete",
              "Metal",
              "Curtain",
              "Foliage",
              null
            ]
          },
          "absorption": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          },
          "damping": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "file"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "fmt": {
            "enum": [
              "glb",
              "gltf",
              "obj",
              "blend"
            ]
          },
          "collision": {
            "enum": [
              "convex",
              "box",
              "file",
              "trimesh",
              "none"
            ]
          },
          "collision_file": {
            "type": [
              "string",
              "null"
            ]
          },
          "blend_object": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "placements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "asset"
        ],
        "additionalProperties": false,
        "properties": {
          "asset": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "z": {
            "type": "number"
          },
          "rot_x": {
            "type": "number"
          },
          "rot_y": {
            "type": "number"
          },
          "rot_z": {
            "type": "number"
          },
          "scale": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "scale_xyz": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "number"
            },
            "minItems": 3,
            "maxItems": 3
          },
          "collision": {
            "enum": [
              "convex",
              "box",
              "file",
              "trimesh",
              "none"
            ]
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "ext_walls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "wall",
          "story"
        ],
        "additionalProperties": false,
        "properties": {
          "wall": {
            "enum": [
              "N",
              "S",
              "E",
              "W"
            ]
          },
          "story": {
            "type": "integer"
          },
          "openings": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/opening"
            }
          },
          "material": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "partitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "story",
          "axis",
          "pos",
          "start",
          "end"
        ],
        "additionalProperties": false,
        "properties": {
          "story": {
            "type": "integer"
          },
          "axis": {
            "enum": [
              "X",
              "Y"
            ]
          },
          "pos": {
            "type": "number"
          },
          "start": {
            "type": "number"
          },
          "end": {
            "type": "number"
          },
          "openings": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/opening"
            }
          },
          "material": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "stairs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "x",
          "y",
          "from_story",
          "to_story"
        ],
        "additionalProperties": false,
        "properties": {
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "from_story": {
            "type": "integer"
          },
          "to_story": {
            "type": "integer"
          },
          "width": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "run": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "style": {
            "enum": [
              "straight",
              "switchback",
              "l_shaped",
              "scissor",
              "spiral"
            ]
          },
          "cut_slabs": {
            "type": "boolean"
          },
          "step_rise": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "n_steps": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 2
          },
          "id": {
            "type": "string"
          },
          "role": {
            "enum": [
              "primary_egress",
              "secondary_egress",
              "exterior_egress",
              "public_convenience",
              "service",
              "private_residential",
              "industrial_access"
            ]
          },
          "stack_id": {
            "type": "string"
          },
          "meta": {
            "type": "object"
          },
          "facing": {
            "enum": [
              "N",
              "S",
              "E",
              "W"
            ]
          },
          "exterior": {
            "type": "boolean"
          },
          "transfer": {
            "type": "boolean"
          }
        }
      }
    },
    "ladders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "x",
          "y",
          "from_story",
          "to_story"
        ],
        "additionalProperties": false,
        "properties": {
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "from_story": {
            "type": "integer"
          },
          "to_story": {
            "type": "integer"
          },
          "width": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "depth": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "rung_spacing": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "cut_slabs": {
            "type": "boolean"
          },
          "facing": {
            "enum": [
              "N",
              "S",
              "E",
              "W"
            ]
          },
          "id": {
            "type": "string"
          },
          "role": {
            "enum": [
              "not_egress",
              "service_access",
              "maintenance_access",
              "roof_access",
              "rooftop_connector",
              "legacy_secondary_escape",
              "fire_escape_termination",
              "special_gameplay_route"
            ]
          },
          "ladder_type": {
            "enum": [
              "fixed_vertical",
              "ship",
              "alternating_tread",
              "caged",
              "safety_rail"
            ]
          },
          "placement_mode": {
            "enum": [
              "interior",
              "exterior_wall",
              "platform",
              "shaft"
            ]
          },
          "lower_surface": {
            "type": "string"
          },
          "upper_surface": {
            "type": "string"
          },
          "direction": {
            "enum": [
              "bidirectional",
              "up_only",
              "down_only",
              "deploy_then_bidirectional",
              "scripted_direction"
            ]
          },
          "access_class": {
            "enum": [
              "public",
              "staff_restricted",
              "maintenance",
              "emergency",
              "gameplay"
            ]
          },
          "counts_as_secondary_escape": {
            "type": "boolean"
          },
          "transition": {
            "enum": [
              "through_step_off",
              "side_step_off",
              "roof_hatch_exit",
              "parapet_cut_through",
              "parapet_crossover_platform",
              "parapet_inside_ladder",
              "platform_gate_entry",
              "fire_escape_platform_entry"
            ]
          },
          "fall_protection": {
            "enum": [
              "none",
              "safety_rail",
              "fall_arrest",
              "cage",
              "rest_platform",
              "offset"
            ]
          },
          "access_control": {
            "enum": [
              "none",
              "locked_gate",
              "ladder_guard",
              "locked_hatch",
              "staff_room",
              "elevated_rung",
              "removable_section",
              "security_enclosure"
            ]
          },
          "fire_escape_id": {
            "type": "string"
          },
          "meta": {
            "type": "object"
          }
        }
      }
    },
    "ramps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "x",
          "y",
          "from_story",
          "to_story"
        ],
        "additionalProperties": false,
        "properties": {
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "from_story": {
            "type": "integer"
          },
          "to_story": {
            "type": "integer"
          },
          "run": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "width": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "axis": {
            "enum": [
              "X",
              "Y"
            ]
          },
          "thickness": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "cut_slabs": {
            "type": "boolean"
          },
          "max_slope_deg": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "vault_ledges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "x",
          "y",
          "story"
        ],
        "additionalProperties": false,
        "properties": {
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "story": {
            "type": "integer"
          },
          "length": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "axis": {
            "enum": [
              "X",
              "Y"
            ]
          },
          "height": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "thick": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "material": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "slab_holes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "story",
          "x",
          "y",
          "size_x",
          "size_y"
        ],
        "additionalProperties": false,
        "properties": {
          "story": {
            "type": "integer"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "size_x": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "size_y": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "volumes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "x",
          "y",
          "z",
          "size_x",
          "size_y",
          "size_z"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "z": {
            "type": "number"
          },
          "size_x": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "size_y": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "size_z": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "collision": {
            "enum": [
              "convex",
              "trimesh",
              "none"
            ]
          },
          "visual": {
            "type": "boolean"
          },
          "material": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "parapets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "story"
        ],
        "additionalProperties": false,
        "properties": {
          "story": {
            "type": "integer"
          },
          "height": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "thick": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "rooms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "story",
          "bounds"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "story": {
            "type": "integer"
          },
          "bounds": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 4,
            "maxItems": 4
          },
          "role": {
            "type": [
              "string",
              "null"
            ]
          },
          "combat_range": {
            "enum": [
              "close",
              "medium",
              "long",
              null
            ]
          },
          "fortifiable": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "objective": {
            "type": "boolean"
          },
          "roofed": {
            "type": "boolean"
          }
        }
      }
    },
    "vertical_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind"
        ],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "enum": [
              "stair",
              "floor_hole",
              "hatch"
            ]
          },
          "role": {
            "type": [
              "string",
              "null"
            ]
          },
          "from_story": {
            "type": [
              "integer",
              "null"
            ]
          },
          "to_story": {
            "type": [
              "integer",
              "null"
            ]
          },
          "story": {
            "type": [
              "integer",
              "null"
            ]
          },
          "x": {
            "type": [
              "number",
              "null"
            ]
          },
          "y": {
            "type": [
              "number",
              "null"
            ]
          },
          "size_x": {
            "type": [
              "number",
              "null"
            ],
            "exclusiveMinimum": 0
          },
          "size_y": {
            "type": [
              "number",
              "null"
            ],
            "exclusiveMinimum": 0
          },
          "breachable": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "cut_slab": {
            "type": "boolean"
          }
        }
      }
    },
    "markers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "additionalProperties": false,
        "properties": {
